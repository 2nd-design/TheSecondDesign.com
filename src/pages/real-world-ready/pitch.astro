---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';

import heroImg from '~/assets/images/real-world-ready/events/btb-winter-camp-dec-2025/workshop-circle-01.jpg';
import grid1 from '~/assets/images/real-world-ready/events/btb-winter-camp-dec-2025/presenter-stage-01.jpg';
import grid2 from '~/assets/images/real-world-ready/events/btb-online-sessions/attendees-dec2025.png';
import grid3 from '~/assets/images/real-world-ready/events/btb-summer-camp-feb-2025/session-openair-04.jpg';
import grid4 from '~/assets/images/real-world-ready/events/btb-online-sessions/session-jan2026-03.png';
import grid5 from '~/assets/images/real-world-ready/events/btb-winter-camp-dec-2025/students-working-01.jpg';
import grid6 from '~/assets/images/real-world-ready/events/btb-winter-camp-dec-2025/workshop-hall-01.jpg';
import zoomImg from '~/assets/images/real-world-ready/events/btb-online-sessions/session-mar2026-40participants.png';

const metadata = {
  title: 'Real World Ready: The Pitch',
  description: "What we've built, how we want to scale it, and what we need to get there.",
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="relative overflow-hidden min-h-[80vh] flex items-end bg-slate-950">

    <!-- Gradient blobs -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute inset-0 bg-gradient-to-br from-violet-600/15 via-slate-950 to-emerald-600/10"></div>
      <div class="absolute top-0 right-1/4 w-[600px] h-[600px] bg-violet-500/20 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] bg-emerald-500/15 rounded-full blur-[100px]"></div>
    </div>

    <!-- Grid overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:60px_60px] pointer-events-none"></div>

    <div class="relative container max-w-4xl mx-auto px-4 sm:px-6 pt-32 pb-20">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-sm mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-violet-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-violet-500"></span>
        </span>
        <span class="text-xs font-medium text-slate-300 tracking-wide">Real World Ready · The Second Design</span>
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-white mb-6 leading-[1.05]">
        What we've built.<br />
        <span class="bg-gradient-to-r from-violet-400 via-blue-400 to-emerald-400 bg-clip-text text-transparent">
          Where we're going.
        </span>
      </h1>

      <p class="text-xl text-slate-400 leading-relaxed max-w-2xl mb-10">
        Running since August 2024. Nearly two years, two seasons, 54 sessions, no breaks. Two delivery partners: TinkerHub Foundation with 85+ campus chapters, and FOSS United for FOSS Hack 2025. Students who show up and engage. Here's what we've built, what we want to do next, and what we need to get there.
      </p>

      <!-- Stat pills -->
      <div class="flex flex-wrap gap-3 mb-14">
        {[
          "54 sessions delivered",
          "1,200+ attendance instances",
          "85+ campus chapters",
          "2 delivery partners",
        ].map(s => (
          <span class="inline-flex items-center px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm text-slate-300 font-medium">
            {s}
          </span>
        ))}
      </div>

      <!-- Hero photo -->
      <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/50 mb-14">
        <Image src={heroImg} alt="Beyond the Blueprint workshop session" class="w-full aspect-[21/9] object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent"></div>
        <div class="absolute bottom-4 left-5 text-xs text-white/40 uppercase tracking-widest font-medium">Beyond the Blueprint · Winter Camp 2025</div>
      </div>

      <!-- Jump links -->
      <div class="pt-8 border-t border-white/10">
        <p class="text-xs uppercase tracking-widest text-slate-500 mb-4">Jump to</p>
        <div class="flex flex-col sm:flex-row gap-3">
          {[
            { label: "01 · What's been done", href: "#what-worked" },
            { label: "02 · How we scale this", href: "#how-to-scale" },
            { label: "03 · What we need", href: "#what-we-need" },
          ].map(link => (
            <a href={link.href}
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/5 border border-white/10 text-sm text-slate-300 font-medium hover:bg-white/10 hover:border-violet-500/40 hover:text-white transition-all duration-200">
              {link.label}
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ============================================================
       BODY
  ============================================================ -->
  <div class="bg-slate-950">
    <div class="container max-w-4xl mx-auto px-4 sm:px-6 py-20 space-y-28">

      <!-- 01 · What Has Worked -->
      <section class="scroll-mt-24" id="what-worked">

        <div class="inline-flex items-center gap-3 mb-8">
          <div class="h-px w-8 bg-gradient-to-r from-violet-500 to-blue-500"></div>
          <span class="text-xs font-bold uppercase tracking-widest text-violet-400">01 · What's Been Done</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-6">
          Nearly two years in. Still going.
        </h2>

        <p class="text-lg text-slate-400 leading-relaxed mb-10">
          Real World Ready has been running since August 2024, nearly two years of live sessions, without a break. Two full seasons, 54 sessions, and still going. Built around specific problems students face, designed so they actually do something, not just listen.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-px rounded-2xl overflow-hidden border border-white/10 mb-10">
          {[
            { n: "55", label: "Sessions delivered" },
            { n: "1,200+", label: "Attendance instances" },
            { n: "85+", label: "Campus chapters reached" },
          ].map((stat, i) => (
            <div class="p-6 text-center bg-white/[0.03] backdrop-blur-sm">
              <p class="text-3xl font-bold bg-gradient-to-r from-violet-400 to-emerald-400 bg-clip-text text-transparent mb-1">{stat.n}</p>
              <p class="text-xs text-slate-500 uppercase tracking-wide">{stat.label}</p>
            </div>
          ))}
        </div>

        <!-- Photo grid -->
        <div class="grid grid-cols-3 gap-2 mb-10">
          <div class="col-span-2 row-span-2 rounded-2xl overflow-hidden border border-white/10">
            <Image src={grid1} alt="Presenter on stage at Beyond the Blueprint camp" class="w-full h-full object-cover aspect-[4/3]" />
          </div>
          <div class="rounded-2xl overflow-hidden border border-white/10">
            <Image src={grid2} alt="Online Zoom session with students" class="w-full h-full object-cover aspect-square" />
          </div>
          <div class="rounded-2xl overflow-hidden border border-white/10">
            <Image src={grid3} alt="Online session participants" class="w-full h-full object-cover aspect-square" />
          </div>
          <div class="rounded-2xl overflow-hidden border border-white/10">
            <Image src={grid4} alt="Zoom session with attendees" class="w-full h-full object-cover aspect-square" />
          </div>
          <div class="rounded-2xl overflow-hidden border border-white/10">
            <Image src={grid5} alt="Students working in session" class="w-full h-full object-cover aspect-square" />
          </div>
          <div class="rounded-2xl overflow-hidden border border-white/10">
            <Image src={grid6} alt="Workshop hall full of students" class="w-full h-full object-cover aspect-square" />
          </div>
        </div>

        <!-- Season breakdown -->
        <div class="grid md:grid-cols-2 gap-4 mb-10">
          <div class="p-5 rounded-2xl bg-white/[0.03] border border-white/10">
            <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-4">Season 1 · Aug 2024 – Jun 2025</p>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-start gap-2"><span class="text-violet-400 mt-0.5">→</span><span>27 sessions across 5 topics</span></li>
              <li class="flex items-start gap-2"><span class="text-violet-400 mt-0.5">→</span><span>Camp session: 105 attendees in a single day</span></li>
              <li class="flex items-start gap-2"><span class="text-violet-400 mt-0.5">→</span><span>Each session iterated 4–6 times per topic</span></li>
            </ul>
          </div>
          <div class="p-5 rounded-2xl bg-white/[0.03] border border-white/10">
            <p class="text-xs font-bold uppercase tracking-widest text-emerald-500/70 mb-4">Season 2 · Nov 2025 – Ongoing</p>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">→</span><span>22 sessions and counting</span></li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">→</span><span>Winter camp at Kochi: 167 attendees in one session</span></li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">→</span><span>61 campuses, 305 students in TinkerHub cohort</span></li>
              <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">→</span><span>Online sessions regularly drawing 25–40 per session</span></li>
            </ul>
          </div>
        </div>

        <!-- The 5 sessions -->
        <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-5">The 5 sessions we've built and tested</p>
        <div class="space-y-3 mb-10">
          {[
            { n: "01", title: "Shitty First Drafts", desc: "Overcoming perfectionism. Students ship a first draft in 90 minutes. 63% rate it 10/10." },
            { n: "02", title: "Understanding Agency", desc: "What high agency looks like in practice. Students map where they're waiting vs. where they could act." },
            { n: "03", title: "Agency in Action", desc: "Applying high-agency thinking to real career decisions students are facing right now." },
            { n: "04", title: "Navigating Your Future", desc: "Careers as systems. Making decisions without a perfect plan." },
            { n: "05", title: "Understanding System Design", desc: "Thinking in systems. Breaking down complex problems, spotting leverage points." },
          ].map(s => (
            <div class="flex items-start gap-5 p-5 rounded-2xl bg-white/[0.03] border border-white/10 hover:border-violet-500/30 transition-colors">
              <span class="text-xl font-bold text-violet-400/40 font-mono shrink-0 leading-none mt-0.5">{s.n}</span>
              <div>
                <p class="font-semibold text-white mb-1">{s.title}</p>
                <p class="text-sm text-slate-400 leading-relaxed">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- How it reaches students -->
        <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-5">How it reaches students</p>
        <p class="text-sm text-slate-400 leading-relaxed mb-6">
          Real World Ready is delivered through organisations with existing reach into student communities. The pedagogy, facilitation, and content come from The Second Design. The community infrastructure comes from the partner.
        </p>

        <!-- TinkerHub -->
        <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/10 mb-4">
          <div class="flex items-start justify-between gap-4 mb-3">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-violet-400 mb-1">Sustained partnership</p>
              <p class="font-semibold text-white">TinkerHub Foundation</p>
            </div>
            <span class="shrink-0 text-xs text-slate-500 bg-white/5 border border-white/10 rounded-full px-3 py-1">Ongoing · Season 1 &amp; 2</span>
          </div>
          <p class="text-sm text-slate-400 leading-relaxed mb-3">
            85+ active campus chapters across Kerala's engineering colleges. Sessions run under the <em>Beyond the Blueprint</em> co-brand. TinkerHub brings the student mobilisation and campus infrastructure; The Second Design brings the programme.
          </p>
          <a href="/blog/beyond-the-blueprint" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-violet-400 hover:text-violet-300 transition-colors">
            Read the Beyond the Blueprint write-up →
          </a>
        </div>

        <!-- FOSS United -->
        <div class="rounded-2xl bg-white/[0.03] border border-white/10 overflow-hidden mb-10">
          <div class="p-6">
            <div class="flex items-start justify-between gap-4 mb-3">
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-blue-400 mb-1">Event collaboration</p>
                <p class="font-semibold text-white">FOSS United</p>
              </div>
              <span class="shrink-0 text-xs text-slate-500 bg-white/5 border border-white/10 rounded-full px-3 py-1">Dec 2024 · FOSS Hack 2025</span>
            </div>
            <p class="text-sm text-slate-400 leading-relaxed mb-4">
              FOSS United runs one of India's largest open-source hackathons. They noticed attendees showing up without a project idea, submitting work without READMEs or licenses. We designed five pre-hackathon sessions helping attendees figure out what to build and how to present it. Custom programme, built from scratch for their context.
            </p>
            <div class="flex gap-6 mb-4">
              {[
                { n: "605", label: "Registrations" },
                { n: "217", label: "Participants" },
                { n: "4.5/5", label: "Avg rating" },
              ].map(s => (
                <div>
                  <p class="text-xl font-bold text-white">{s.n}</p>
                  <p class="text-xs text-slate-500 uppercase tracking-wide">{s.label}</p>
                </div>
              ))}
            </div>
            <div class="flex flex-wrap gap-5">
              <a href="/blog/real-world-ready-foss-hack-2025" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-blue-400 hover:text-blue-300 transition-colors">
                Read our case study →
              </a>
              <a href="https://fossunited.org/blog/foss-events/fosshack2025-the-second-design" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-slate-300 transition-colors">
                FOSS United's write-up →
              </a>
            </div>
          </div>
          <!-- Rahul Poruri video -->
          <div class="border-t border-white/10">
            <div class="px-6 pt-4 pb-2">
              <p class="text-xs text-slate-500 uppercase tracking-widest">Rahul Poruri, CEO · FOSS United</p>
            </div>
            <div class="aspect-video">
              <iframe
                src="https://www.youtube.com/embed/vd9-Ayw7WNU"
                title="Rahul Poruri, CEO of FOSS United, on the collaboration with The Second Design"
                class="w-full h-full"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            </div>
          </div>
        </div>

        <!-- Mehar Ranadive on Real World Ready -->
        <div class="rounded-2xl bg-white/[0.03] border border-white/10 overflow-hidden mb-10">
          <div class="aspect-video">
            <iframe
              src="https://www.youtube.com/embed/AI7YX97Fn2s"
              title="Mehar MP, Founder of TinkerHub, on Real World Ready"
              class="w-full h-full"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
          <div class="p-6">
            <a href="https://www.linkedin.com/in/meharmp" target="_blank" rel="noopener noreferrer" class="inline-block text-xs font-bold uppercase tracking-widest text-violet-400 hover:text-violet-300 transition-colors mb-2">Mehar MP · Founder, TinkerHub →</a>
            <blockquote class="text-slate-300 italic text-sm leading-relaxed mb-4">
              "If people have at least what I went through -- agency in themselves, and the ability to recognise it -- that itself is going to be a great revolution."
            </blockquote>
            <p class="text-sm text-slate-500 leading-relaxed">
              If this resonates, we're happy to talk through the design philosophy behind it: why we build sessions the way we do, and what makes them different.
            </p>
          </div>
        </div>

        <!-- Online session photo -->
        <div class="rounded-2xl overflow-hidden border border-white/10 mb-10">
          <Image src={zoomImg} alt="Online session with 40+ participants" class="w-full aspect-[16/7] object-cover" />
          <div class="px-5 py-3 bg-white/[0.03] border-t border-white/10">
            <p class="text-xs text-slate-500 uppercase tracking-widest">Online sessions now regularly drawing 25–40 participants</p>
          </div>
        </div>

        <!-- Quotes -->
        <div class="space-y-4 mb-10">
          {[
            { q: "Your first step can be chaotic and still be valid.", a: "Arjun Vibeesh, Beyond the Blueprint" },
            { q: "Gave 9/10 only because the session was too short: I didn't want it to end.", a: "Niranjana, Beyond the Blueprint" },
            { q: "It's not about being perfect. It's about starting.", a: "Arsha, Beyond the Blueprint" },
          ].map(item => (
            <blockquote class="border-l-2 border-violet-500/50 pl-5 py-1">
              <p class="text-slate-300 italic mb-1">"{item.q}"</p>
              <p class="text-xs text-slate-600 uppercase tracking-wide">{item.a}</p>
            </blockquote>
          ))}
        </div>

        <!-- Video testimonials -->
        <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-5">In their own words</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
          {[
            { id: "ntWpaUSVnHg", quote: "If you get an opportunity, don't throw it away. Take it." },
            { id: "jjv7qU_42Zc", quote: "I wasn't aware of the Shitty First Draft technique. After learning it, I was mind blown. It was a Eureka moment." },
            { id: "JRDIhgZo9AE", quote: "They handed the mic to everyone. No host-participant divide. That made me far more willing to speak up." },
            { id: "1qBZ1Zn9CWo", quote: "The way you guys curate this: it's a model that an education system has to follow." },
          ].map(v => (
            <div class="flex flex-col gap-3">
              <div class="rounded-xl overflow-hidden border border-white/10">
                <iframe
                  src={`https://www.youtube.com/embed/${v.id}`}
                  title={v.quote}
                  class="w-full aspect-[9/16]"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              </div>
              <p class="text-xs text-slate-500 italic leading-relaxed">"{v.quote}"</p>
            </div>
          ))}
        </div>
        <div class="mb-10 text-right">
          <a href="/testimonials" class="text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-violet-400 transition-colors">
            See all testimonials →
          </a>
        </div>

        <!-- Proof of Work -->
        <div class="p-6 rounded-2xl bg-gradient-to-br from-violet-500/10 to-emerald-500/10 border border-violet-500/20">
          <p class="text-xs font-bold uppercase tracking-widest text-violet-400 mb-3">Proof of Work</p>
          <p class="text-sm text-slate-400 leading-relaxed mb-4">
            Beyond ratings, we track students who took real action after attending: started a project, made a career decision, reached out to someone they admired. Documented as <strong class="text-white/80">Proof of Work</strong> episodes: a decision, the steps taken, and the outcome.
          </p>
          <a href="https://theseconddesign.com/proof-of-work" target="_blank" rel="noreferrer"
            class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-violet-400 hover:text-violet-300 transition-colors">
            View episodes →
          </a>
        </div>

      </section>

      <!-- 02 · How We Scale This -->
      <section class="scroll-mt-24 pt-10 border-t border-white/10" id="how-to-scale">

        <div class="inline-flex items-center gap-3 mb-8">
          <div class="h-px w-8 bg-gradient-to-r from-blue-500 to-emerald-500"></div>
          <span class="text-xs font-bold uppercase tracking-widest text-blue-400">02 · How We Scale This</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-6">
          Four ways to reach more students.
        </h2>

        <p class="text-lg text-slate-400 leading-relaxed mb-10">
          We've been thinking about scale in four ways. Three are straightforward. The fourth surprised us.
        </p>

        <div class="space-y-4 mb-12">
          {[
            {
              n: "01",
              title: "Conduct more sessions",
              desc: "More frequency, more campuses, more delivery partners. The session format is proven. Reach grows directly with the number of times we run it.",
              color: "text-blue-400/40",
              border: "hover:border-blue-500/30",
            },
            {
              n: "02",
              title: "More students per session",
              desc: "Sessions have gone from 20 students to 167 in a single room. With better logistics, partner infrastructure, and online reach, each session can go wider.",
              color: "text-blue-400/40",
              border: "hover:border-blue-500/30",
            },
            {
              n: "03",
              title: "More topics",
              desc: "We have 5 sessions today. Each new topic addresses a different problem students face, bringing a new reason to attend. We are building 10 more.",
              color: "text-blue-400/40",
              border: "hover:border-blue-500/30",
            },
            {
              n: "04",
              title: "Students run sessions themselves",
              desc: "Two of our sessions are open-sourced under Creative Commons. Students at campuses we have never visited have started facilitating them for their own communities, entirely on their own. No budget. No coordination from us. This kind of scale doesn't show up in our session count. It doesn't require our time or travel. It's already happening.",
              color: "text-emerald-400/60",
              border: "hover:border-emerald-500/30",
              link: { href: "/blog/students-ran-our-sessions-themselves", label: "Read the full story" },
            },
          ].map(item => (
            <div class={`flex items-start gap-5 p-5 rounded-2xl bg-white/[0.03] border border-white/10 transition-colors ${item.border}`}>
              <span class={`text-2xl font-bold font-mono shrink-0 leading-none mt-0.5 w-8 ${item.color}`}>{item.n}</span>
              <div>
                <p class="font-bold text-white mb-2">{item.title}</p>
                <p class="text-sm text-slate-400 leading-relaxed">{item.desc}</p>
                {item.link && (
                  <a href={item.link.href}
                    class="inline-flex items-center gap-1 mt-3 text-xs font-bold uppercase tracking-widest text-emerald-400 hover:text-emerald-300 transition-colors">
                    {item.link.label} →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Format flexibility -->
        <div class="p-5 rounded-2xl bg-white/[0.03] border border-white/10 mb-12">
          <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-4">How sessions are structured</p>
          <div class="grid md:grid-cols-3 gap-6">
            {[
              { label: "Signature series", desc: "Multi-week programmes with recurring cohorts. Our default format with TinkerHub: students attend across a semester, building on each session." },
              { label: "Intensive bootcamps", desc: "2-5 days of concentrated sessions. Higher commitment, deeper impact. Our camp format has brought 100+ students together in a single day." },
              { label: "Standalone sessions", desc: "One-off sessions designed around a partner's specific moment or context. Like FOSS Hack: a custom programme for an existing event." },
            ].map(f => (
              <div>
                <p class="text-sm font-semibold text-white mb-1">{f.label}</p>
                <p class="text-xs text-slate-500 leading-relaxed">{f.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- By end of Year 1 -->
        <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-5">Where we want to be in a year</p>
        <div class="grid md:grid-cols-2 gap-3">
          {[
            {
              n: "15 sessions",
