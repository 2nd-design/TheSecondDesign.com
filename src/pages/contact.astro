---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contact',
  description:
    'Tell us about your learners, your context, and what you want to make possible. You can either send us a detailed note or book a 30-minute inquiry call.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="bg-slate-50 border-b border-slate-200 dark:bg-slate-950 dark:border-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-20 text-center space-y-6">
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight text-slate-900 dark:text-white">Contact</h1>
      <p class="text-lg sm:text-xl text-slate-700 dark:text-slate-300 leading-relaxed max-w-2xl mx-auto">
        There are two simple ways to start working with us: send a detailed message, or book a 30-minute inquiry call.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center pt-2">
        <a
          href="https://cal.com/the-second-design/30min"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold
                 bg-slate-900 text-slate-50 shadow-sm hover:bg-slate-800
                 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100
                 transition"
        >
          Book a 30-minute inquiry call
        </a>

        <a
          href="#contact-form"
          class="inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold
                 border border-slate-300 text-slate-800 bg-white/80 hover:bg-white
                 dark:border-slate-700 dark:text-slate-100 dark:bg-slate-900/60 dark:hover:bg-slate-900
                 transition"
        >
          Send us a message instead
        </a>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="bg-white dark:bg-slate-950">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-20">
      <div class="grid gap-12 md:grid-cols-2 items-start">
        <!-- Left: guidance + call option -->
        <div class="space-y-8 text-slate-900 dark:text-slate-200">
          <div class="space-y-3">
            <h2 class="text-2xl font-semibold">How we like to use this page</h2>

            <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed">
              Use this page to start a conversation about:
            </p>

            <ul class="space-y-2 text-sm text-slate-800 dark:text-slate-200">
              <li>• Designing a new learning program for your organisation</li>
              <li>• Running Real World Ready with your attendees or community</li>
              <li>• Reviewing or improving an existing program</li>
              <li>• Exploring a one-off pilot or experiment</li>
            </ul>

            <p class="text-xs text-slate-500 dark:text-slate-500 leading-relaxed max-w-md">
              If you’re not sure how to describe what you need, that’s fine. Write in plain language. We care more about
              understanding your reality than getting a “perfect brief”.
            </p>
          </div>

          <!-- Call booking card -->
          <div
            class="rounded-2xl border bg-slate-50/80 text-slate-900 px-5 py-4 space-y-3
                   border-slate-200
                   dark:bg-slate-900/70 dark:border-slate-800 dark:text-slate-50"
          >
            <h3 class="text-sm font-semibold tracking-tight">Prefer to talk live?</h3>
            <p class="text-xs text-slate-700 dark:text-slate-300 leading-relaxed">
              You can skip the back-and-forth and book a
              <span class="font-medium">30-minute inquiry call</span> with us. We’ll use it to understand your learners,
              constraints, and what you’re trying to make possible.
            </p>
            <a
              href="https://cal.com/the-second-design/30min"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-lg px-4 py-2 text-xs font-semibold
                     bg-slate-900 text-slate-50 hover:bg-slate-800
                     dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100
                     transition"
            >
              Book a 30-minute call
            </a>
            <p class="text-[11px] text-slate-500 dark:text-slate-500 leading-relaxed">
              If there’s no obvious fit, we’ll say so clearly and point you to other options if we can.
            </p>
          </div>
        </div>

        <!-- Right: form card -->
        <div
          id="contact-form"
          class="rounded-3xl border bg-white text-slate-900 shadow-xl p-6 sm:p-8
                 border-slate-200 shadow-slate-200/80
                 dark:bg-slate-900 dark:text-slate-50 dark:border-slate-800 dark:shadow-black/60"
        >
          <form id="contact-form-element" class="space-y-5">

            <div class="space-y-1">
              <label class="text-xs font-medium text-slate-700 dark:text-slate-300" for="name">Your name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                class="w-full rounded-xl border px-3 py-2 text-sm
                       bg-white border-slate-300 text-slate-900 placeholder:text-slate-400
                       focus:outline-none focus:ring-2 focus:ring-slate-300 focus:border-slate-400
                       dark:bg-slate-950 dark:border-slate-700 dark:text-slate-50 dark:placeholder:text-slate-500 dark:focus:ring-slate-300"
              />
            </div>

            <div class="space-y-1">
              <label class="text-xs font-medium text-slate-700 dark:text-slate-300" for="email">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="w-full rounded-xl border px-3 py-2 text-sm
                       bg-white border-slate-300 text-slate-900 placeholder:text-slate-400
                       focus:outline-none focus:ring-2 focus:ring-slate-300 focus:border-slate-400
                       dark:bg-slate-950 dark:border-slate-700 dark:text-slate-50 dark:placeholder:text-slate-500 dark:focus:ring-slate-300"
              />
            </div>

            <div class="space-y-1">
              <label class="text-xs font-medium text-slate-700 dark:text-slate-300" for="org">
                Organisation / context
              </label>
              <input
                id="org"
                name="organisation"
                type="text"
                placeholder="College, NGO, company, community…"
                class="w-full rounded-xl border px-3 py-2 text-sm
                       bg-white border-slate-300 text-slate-900 placeholder:text-slate-400
                       focus:outline-none focus:ring-2 focus:ring-slate-300 focus:border-slate-400
                       dark:bg-slate-950 dark:border-slate-700 dark:text-slate-50 dark:placeholder:text-slate-500 dark:focus:ring-slate-300"
              />
            </div>

            <div class="space-y-1">
              <label class="text-xs font-medium text-slate-700 dark:text-slate-300" for="interest">
                What would you like to explore?
              </label>
              <select
                id="interest"
                name="interest"
                class="w-full rounded-xl border px-3 py-2 text-sm
                       bg-white border-slate-300 text-slate-900
                       focus:outline-none focus:ring-2 focus:ring-slate-300 focus:border-slate-400
                       dark:bg-slate-950 dark:border-slate-700 dark:text-slate-50 dark:focus:ring-slate-300"
              >
                <option value="">Choose an option</option>
                <option value="new-program">Designing a new learning program</option>
                <option value="real-world-ready">Running Real World Ready</option>
                <option value="improve-existing">Improving an existing program</option>
                <option value="other">Something else</option>
              </select>
            </div>

            <div class="space-y-1">
              <label class="text-xs font-medium text-slate-700 dark:text-slate-300" for="message">
                Tell us a bit about your learners and what you want to make possible
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="w-full rounded-xl border px-3 py-2 text-sm resize-none
                       bg-white border-slate-300 text-slate-900 placeholder:text-slate-400
                       focus:outline-none focus:ring-2 focus:ring-slate-300 focus:border-slate-400
                       dark:bg-slate-950 dark:border-slate-700 dark:text-slate-50 dark:placeholder:text-slate-500 dark:focus:ring-slate-300"
              ></textarea>
            </div>

            <div class="pt-2">
              <button
                type="submit"
                id="submit-btn"
                class="inline-flex items-center justify-center rounded-xl px-4 py-2.5 text-sm font-semibold
                       bg-slate-900 text-slate-50 shadow-sm hover:bg-slate-800
                       dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100
                       transition disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <span id="btn-text">Send message</span>
                <span id="btn-loading" class="hidden">Sending...</span>
              </button>
            </div>

            <p class="text-[11px] text-slate-500 dark:text-slate-500 leading-relaxed pt-1">
              We read every message. If it makes sense to speak live, we'll reply with a link to this same 30-minute
              call, or suggest a different next step if that's more useful.
            </p>

            <!-- Success message -->
            <div id="success-message" class="hidden rounded-xl bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 p-4">
              <p class="text-sm text-emerald-800 dark:text-emerald-200 font-medium">Message sent successfully!</p>
              <p class="text-xs text-emerald-600 dark:text-emerald-400 mt-1">We'll get back to you soon.</p>
            </div>

            <!-- Error message -->
            <div id="error-message" class="hidden rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-4">
              <p class="text-sm text-red-800 dark:text-red-200 font-medium">Something went wrong.</p>
              <p class="text-xs text-red-600 dark:text-red-400 mt-1">Please try again or email us directly.</p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    const GOOGLE_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzTgnEstlYvIolaCPq6pQtM2aGUi0vuESwZ59QJn8SpbbR96jD1syJ7IYB4zisFk_jDbQ/exec";

    document.getElementById("contact-form-element").addEventListener("submit", async function(e) {
      e.preventDefault();

      const form = e.target;
      const submitBtn = document.getElementById("submit-btn");
      const btnText = document.getElementById("btn-text");
      const btnLoading = document.getElementById("btn-loading");
      const successMsg = document.getElementById("success-message");
      const errorMsg = document.getElementById("error-message");

      // Hide any previous messages
      successMsg.classList.add("hidden");
      errorMsg.classList.add("hidden");

      // Show loading state
      submitBtn.disabled = true;
      btnText.classList.add("hidden");
      btnLoading.classList.remove("hidden");

      // Collect form data
      const formData = {
        name: form.querySelector("#name").value,
        email: form.querySelector("#email").value,
        organisation: form.querySelector("#org").value,
        interest: form.querySelector("#interest").value,
        message: form.querySelector("#message").value
      };

      try {
        await fetch(GOOGLE_SCRIPT_URL, {
          method: "POST",
          mode: "no-cors",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(formData)
        });

        // Show success (we use no-cors so we can't read the response, but it usually works)
        successMsg.classList.remove("hidden");
        form.reset();

      } catch (error) {
        console.error("Form submission error:", error);
        errorMsg.classList.remove("hidden");
      } finally {
        // Reset button state
        submitBtn.disabled = false;
        btnText.classList.remove("hidden");
        btnLoading.classList.add("hidden");
      }
    });
  </script>
</Layout>
