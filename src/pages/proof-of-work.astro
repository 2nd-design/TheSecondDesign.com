---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { fetchEpisodes } from '~/utils/episodes';

const episodes = await fetchEpisodes();

function getYoutubeId(url?: string) {
  if (!url) return null;
  return url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([\w-]{11})/)?.[1] ?? null;
}

const metadata = {
  title: 'Proof of Work',
  description:
    'Students who decided to act. They started projects, organised events, shipped work, and made decisions without waiting for permission.',
};
---

<Layout metadata={metadata}>
  <!-- Hero ************************************* -->
  <section class="relative overflow-hidden min-h-[90vh] flex items-center bg-slate-950">
    <!-- Background image -->
    <img
      src="https://images.unsplash.com/photo-1735892907432-569ee8e8cc1b?auto=format&fit=crop&w=1920&q=80"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
    />

    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-slate-950/70"></div>

    <!-- Colored gradient accents -->
    <div class="absolute inset-0">
      <div class="absolute top-1/4 left-0 w-[700px] h-[700px] bg-blue-500/15 rounded-full blur-[150px] animate-pulse"></div>
      <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-violet-500/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 1.5s;"></div>
      <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-emerald-500/10 rounded-full blur-[100px] animate-pulse" style="animation-delay: 3s;"></div>
    </div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:60px_60px]"></div>

    <div class="relative container max-w-5xl mx-auto px-4 sm:px-6 py-20">
      <div class="text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-sm mb-10">
          <Icon name="tabler:microphone-2" class="w-4 h-4 text-blue-400" />
          <span class="text-xs font-medium text-slate-300 tracking-wide">The Second Design Presents</span>
        </div>

        <!-- Main headline -->
        <h1 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-bold tracking-tight text-white mb-8 leading-[0.9]">
          Proof of
          <span class="block bg-gradient-to-r from-blue-400 via-violet-400 to-emerald-400 bg-clip-text text-transparent">
            Work
          </span>
        </h1>

        <p class="text-xl sm:text-2xl text-slate-400 leading-relaxed max-w-2xl mx-auto mb-6">
          Students who decided to act.
        </p>

        <p class="text-base text-slate-500 max-w-xl mx-auto">
          They didn't wait for permission. They started projects, organised events, shipped work, and made decisions. These are their stories.
        </p>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-500">
      <span class="text-xs tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-slate-500 to-transparent"></div>
    </div>
  </section>

  <!-- The concept ****************************** -->
  <section class="py-24 sm:py-32 bg-white dark:bg-slate-950 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-slate-200 dark:via-slate-800 to-transparent"></div>

    <div class="container max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Text -->
        <div class="space-y-8">
          <div class="space-y-4">
            <p class="text-sm font-semibold tracking-[0.2em] text-blue-600 dark:text-blue-400 uppercase">The concept</p>
            <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 dark:text-white">
              Not inspiration.<br/>
              <span class="text-slate-400 dark:text-slate-500">Evidence.</span>
            </h2>
          </div>
          <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
            This is not a collection of "inspiring stories" about talented people doing impressive things. This is documentation. Students from ordinary colleges, with ordinary resources, who made a specific decision: to act before they felt ready.
          </p>
          <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
            Every episode follows the same structure: What they decided. What they did. What happened. No motivational framing. Just the steps.
          </p>
        </div>

        <!-- Visual cards -->
        <div class="space-y-4">
          <div class="p-6 rounded-2xl bg-gradient-to-br from-blue-500/10 to-blue-500/5 border border-blue-500/20">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center">
                <Icon name="tabler:target-arrow" class="w-6 h-6 text-blue-500 dark:text-blue-400" />
              </div>
              <div>
                <h3 class="font-semibold text-slate-900 dark:text-white mb-1">The decision</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">What specific moment or choice set things in motion.</p>
              </div>
            </div>
          </div>

          <div class="p-6 rounded-2xl bg-gradient-to-br from-violet-500/10 to-violet-500/5 border border-violet-500/20">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-violet-500/20 flex items-center justify-center">
                <Icon name="tabler:list-check" class="w-6 h-6 text-violet-500 dark:text-violet-400" />
              </div>
              <div>
                <h3 class="font-semibold text-slate-900 dark:text-white mb-1">The steps</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">Exactly what they did, in order. No hand-waving.</p>
              </div>
            </div>
          </div>

          <div class="p-6 rounded-2xl bg-gradient-to-br from-emerald-500/10 to-emerald-500/5 border border-emerald-500/20">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center">
                <Icon name="tabler:circuit-ground" class="w-6 h-6 text-emerald-500 dark:text-emerald-400" />
              </div>
              <div>
                <h3 class="font-semibold text-slate-900 dark:text-white mb-1">What happened</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">The real outcome. Not a fairy tale. Just what changed.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured episode ************************* -->
  {episodes.length > 0 && (
    <section class="py-24 sm:py-32 bg-slate-950 text-white relative overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-b from-blue-500/15 to-transparent blur-3xl"></div>

      <div class="relative container max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-16">
          <p class="text-sm font-semibold tracking-[0.2em] text-blue-400 uppercase mb-4">Latest Episode</p>
          <h2 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">
            {episodes[0].title}
          </h2>
          <p class="text-lg text-slate-400">{episodes[0].studentName}</p>
        </div>

        <div class="max-w-5xl mx-auto">
          <!-- Featured card -->
          <a
            href={`/proof-of-work/${episodes[0].slug}`}
            class="group block relative rounded-3xl overflow-hidden"
          >
            <!-- Large gradient card -->
            <div class="relative p-8 sm:p-12 md:p-16 bg-gradient-to-br from-blue-600/90 via-blue-700/80 to-violet-700/70 rounded-3xl border border-white/10">
              <!-- Decorative blobs -->
              <div class="absolute top-0 right-0 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
              <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-400/20 rounded-full blur-2xl"></div>
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-violet-500/10 rounded-full blur-3xl"></div>

              <div class="relative grid md:grid-cols-2 gap-10 items-center">
                <!-- Text side -->
                <div class="space-y-6">
                  <div class="flex items-center gap-2">
                    {episodes[0].tags?.map((tag) => (
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-white/15 text-white/90 border border-white/20 backdrop-blur-sm">
                        {tag}
                      </span>
                    ))}
                  </div>

                  <blockquote class="text-3xl sm:text-4xl font-bold leading-tight">
                    "Build before you figure it out."
                  </blockquote>

                  <p class="text-blue-100 text-lg leading-relaxed">
                    {episodes[0].excerpt}
                  </p>

                  <div class="flex items-center gap-3 text-white font-semibold group-hover:gap-4 transition-all">
                    <span>{episodes[0].videoUrl ? 'Watch & read' : 'Read the full story'}</span>
                    <Icon name="tabler:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
                  </div>
                </div>

                <!-- Visual side -->
                <div class="hidden md:flex flex-col items-center justify-center">
                  {(() => {
                    const ytId = getYoutubeId(episodes[0].videoUrl);
                    return ytId ? (
                      <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/40 w-full aspect-video group-hover:scale-[1.02] transition-transform duration-300">
                        <img
                          src={`https://img.youtube.com/vi/${ytId}/maxresdefault.jpg`}
                          alt={`${episodes[0].title} video thumbnail`}
                          class="w-full h-full object-cover"
                        />
                        <div class="absolute inset-0 bg-black/30 flex items-center justify-center">
                          <div class="w-16 h-16 rounded-full bg-white/90 flex items-center justify-center shadow-xl">
                            <svg class="w-6 h-6 text-slate-900 ml-1" fill="currentColor" viewBox="0 0 24 24">
                              <path d="M8 5v14l11-7z"/>
                            </svg>
                          </div>
                        </div>
                        <div class="absolute bottom-3 left-3 px-2.5 py-1 rounded-full bg-black/60 backdrop-blur-sm text-xs font-medium text-white/90">
                          Watch episode
                        </div>
                      </div>
                    ) : (
                      <div class="text-[12rem] font-black leading-none text-white/10 select-none">01</div>
                    );
                  })()}
                </div>
              </div>
            </div>
          </a>

          <!-- Episode details bar -->
          <div class="mt-6 flex flex-wrap items-center justify-center gap-6 text-sm text-slate-400">
            <div class="flex items-center gap-2">
              <Icon name="tabler:user" class="w-4 h-4" />
              <span>{episodes[0].studentName}</span>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="tabler:school" class="w-4 h-4" />
              <span>LBS Institute of Technology for Women, Trivandrum</span>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="tabler:brand-github" class="w-4 h-4" />
              <span>46 repositories</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Key quote ******************************** -->
  <section class="py-20 sm:py-28 bg-white dark:bg-slate-950 relative">
    <div class="container max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <Icon name="tabler:quote" class="w-12 h-12 text-slate-200 dark:text-slate-800 mx-auto mb-8" />
      <blockquote class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-white leading-tight mb-8">
        These are not exceptional students. These are students who
        <span class="bg-gradient-to-r from-blue-600 to-violet-600 dark:from-blue-400 dark:to-violet-400 bg-clip-text text-transparent"> decided to act.</span>
      </blockquote>
      <div class="w-16 h-px bg-slate-300 dark:bg-slate-700 mx-auto"></div>
    </div>
  </section>

  <!-- More episodes / Coming soon ************** -->
  <section class="py-24 sm:py-32 bg-slate-50 dark:bg-slate-900/50">
    <div class="container max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-sm font-semibold tracking-[0.2em] text-violet-600 dark:text-violet-400 uppercase mb-4">Coming up</p>
        <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 dark:text-white mb-6">
          More stories in the making
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-400">
          We're documenting more students who decided to act. Each story follows the same format: the decision, the steps, and what happened.
        </p>
      </div>

      <div class="max-w-xs mx-auto">
        <div class="relative rounded-2xl border-2 border-dashed border-slate-300 dark:border-slate-700 p-8 flex flex-col items-center justify-center text-center min-h-[180px]">
          <div class="w-12 h-12 rounded-xl bg-slate-200 dark:bg-slate-800 flex items-center justify-center mb-4">
            <Icon name="tabler:microphone-2" class="w-6 h-6 text-slate-400 dark:text-slate-500" />
          </div>
          <p class="text-sm font-semibold text-slate-400 dark:text-slate-500">Episode 02</p>
          <p class="text-xs text-slate-400 dark:text-slate-600 mt-1">Coming soon</p>
        </div>
      </div>

      {episodes.length > 1 && (
        <div class="mt-16 grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {episodes.slice(1).map((episode, index) => (
            <a
              href={`/proof-of-work/${episode.slug}`}
              class="group relative bg-white dark:bg-slate-900 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-xl hover:border-slate-300 dark:hover:border-slate-700 transition-all duration-300 hover:-translate-y-1"
            >
              <div class="p-6 sm:p-8">
                <span class="text-xs font-bold text-slate-400 dark:text-slate-500 tracking-widest uppercase mb-3 block">Episode {String(index + 2).padStart(2, '0')}</span>
                <div class="flex items-center gap-2 mb-4">
                  {episode.tags?.map((tag) => (
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-500/10 text-blue-700 dark:text-blue-300 border border-blue-500/20">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  {episode.title}
                </h3>
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-3">{episode.studentName}</p>
                {episode.excerpt && (
                  <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{episode.excerpt}</p>
                )}
                <div class="mt-4 flex items-center gap-2 text-sm font-medium text-blue-600 dark:text-blue-400">
                  <span>Read story</span>
                  <Icon name="tabler:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA *************************************** -->
  <section class="py-24 sm:py-32 bg-slate-950 relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-500/15 rounded-full blur-[150px]"></div>
      <div class="absolute top-0 right-0 w-96 h-96 bg-violet-500/10 rounded-full blur-[100px]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
    </div>

    <div class="relative container max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-white mb-6">
        Want this for
        <span class="bg-gradient-to-r from-blue-400 to-violet-400 bg-clip-text text-transparent"> your students?</span>
      </h2>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto mb-10">
        Real World Ready is the program behind these stories. It's how students go from passively waiting to actively deciding. Start with a free session.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="group inline-flex items-center justify-center gap-2 rounded-full bg-white text-slate-900
                 px-10 py-5 text-base font-semibold shadow-2xl shadow-white/20
                 hover:bg-slate-100 transition-all duration-300 hover:scale-105"
        >
          Run the free Shitty First Draft session
          <Icon name="tabler:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
        </a>
        <a
          href="/real-world-ready"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-white/5 border border-white/10 text-white
                 px-10 py-5 text-base font-semibold backdrop-blur-sm
                 hover:bg-white/10 transition-all duration-300"
        >
          Learn about Real World Ready
        </a>
      </div>
    </div>
  </section>
</Layout>
