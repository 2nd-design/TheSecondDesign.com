---
import '@fontsource-variable/playfair-display';
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/cormorant';
import '@fontsource/libre-baskerville';
import '@fontsource-variable/dm-sans';

const heading = 'We Told 220 Students Our Sessions Were Open Source';
const subheading = 'Real World Ready';
const body = `We had been thinking about scale in three ways. Launch more topics, increase the number of students per session, conduct more sessions. These felt like the natural levers. Then something happened that wasn't in any of those three plans. Students at campuses we had never visited started facilitating our sessions themselves — and we realised we had stumbled onto a fourth way to scale.`;
const pullquote = `"Agency is one of the core things we teach. Watching students facilitate a session about agency on their own campus is probably the most literal proof that the idea landed."`;

const options = [
  {
    id: 'A',
    name: 'The Economist',
    description: 'Playfair Display + Source Serif 4',
    headingFont: 'Playfair Display Variable',
    bodyFont: 'Source Serif 4 Variable',
  },
  {
    id: 'B',
    name: 'Old World Refinement',
    description: 'Cormorant + Libre Baskerville',
    headingFont: 'Cormorant Variable',
    bodyFont: 'Libre Baskerville',
  },
  {
    id: 'C',
    name: 'Modern Editorial',
    description: 'Playfair Display + DM Sans',
    headingFont: 'Playfair Display Variable',
    bodyFont: 'DM Sans Variable',
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Font Preview — Internal</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { background: #f5f3ef; }

      .page-header {
        background: #1a1a1a;
        color: #fff;
        padding: 1.5rem 2rem;
        font-family: 'DM Sans Variable', sans-serif;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .options {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        min-height: 100vh;
      }

      @media (max-width: 900px) {
        .options { grid-template-columns: 1fr; }
      }

      .option {
        padding: 3rem 2.5rem;
        border-right: 1px solid #ddd;
        background: #fff;
      }
      .option:last-child { border-right: none; }

      .option-label {
        font-family: 'DM Sans Variable', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 0.4rem;
      }

      .option-name {
        font-family: 'DM Sans Variable', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: #111;
        margin-bottom: 0.2rem;
      }

      .option-desc {
        font-family: 'DM Sans Variable', sans-serif;
        font-size: 0.78rem;
        color: #999;
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid #eee;
      }

      .sample-category {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 0.75rem;
      }

      .sample-heading {
        font-size: 2rem;
        line-height: 1.15;
        color: #111;
        margin-bottom: 1.25rem;
        font-weight: 700;
      }

      .sample-body {
        font-size: 1rem;
        line-height: 1.75;
        color: #333;
        margin-bottom: 1.5rem;
      }

      .sample-pullquote {
        font-size: 1.1rem;
        line-height: 1.6;
        color: #444;
        padding-left: 1.25rem;
        border-left: 3px solid #111;
        margin-bottom: 1.5rem;
        font-style: italic;
      }

      .sample-nav {
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        color: #555;
        display: flex;
        gap: 1.5rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #eee;
      }

      /* Option A */
      .option-A .sample-heading { font-family: 'Playfair Display Variable', serif; }
      .option-A .sample-body { font-family: 'Source Serif 4 Variable', serif; }
      .option-A .sample-pullquote { font-family: 'Source Serif 4 Variable', serif; }
      .option-A .sample-nav { font-family: 'Source Serif 4 Variable', serif; }

      /* Option B */
      .option-B .sample-heading { font-family: 'Cormorant Variable', serif; font-size: 2.4rem; font-weight: 600; }
      .option-B .sample-body { font-family: 'Libre Baskerville', serif; font-size: 0.95rem; }
      .option-B .sample-pullquote { font-family: 'Libre Baskerville', serif; font-size: 1rem; }
      .option-B .sample-nav { font-family: 'Libre Baskerville', serif; font-size: 0.75rem; }

      /* Option C */
      .option-C .sample-heading { font-family: 'Playfair Display Variable', serif; }
      .option-C .sample-body { font-family: 'DM Sans Variable', sans-serif; font-size: 0.95rem; line-height: 1.7; }
      .option-C .sample-pullquote { font-family: 'DM Sans Variable', sans-serif; font-size: 1rem; font-style: normal; font-weight: 500; }
      .option-C .sample-nav { font-family: 'DM Sans Variable', sans-serif; }
    </style>
  </head>
  <body>
    <div class="page-header">Font Preview — Internal · Pick one, then tell me</div>
    <div class="options">
      {options.map((opt) => (
        <div class={`option option-${opt.id}`}>
          <div class="option-label">Option {opt.id}</div>
          <div class="option-name">{opt.name}</div>
          <div class="option-desc">{opt.description}</div>

          <div class="sample-nav">
            <span>Real World Ready</span>
            <span>Blog</span>
            <span>Contact</span>
          </div>

          <div class="sample-category">{subheading}</div>
          <h1 class="sample-heading">{heading}</h1>
          <p class="sample-body">{body}</p>
          <blockquote class="sample-pullquote">{pullquote}</blockquote>
          <p class="sample-body">We gave them the link. We moved on. We didn't expect much to happen with it. A few weeks later, messages started coming in.</p>
        </div>
      ))}
    </div>
  </body>
</html>
