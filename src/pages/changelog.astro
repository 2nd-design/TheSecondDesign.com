---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Changelog',
  description: 'A log of updates and changes made to The Second Design website.',
};

const changelog = [
  {
    date: '2026-03-08',
    version: '1.7.0',
    title: 'Testimonials filtering & site-wide terminology update',
    changes: [
      {
        category: 'Testimonials Page',
        items: [
          'Added product filter with instant client-side filtering — groups by base product name (e.g., "Real World Ready" instead of showing variants separately)',
          'Restructured testimonial card layout — person info and credentials now at top, product info moved to bottom',
          'Product names display with visual hierarchy — base product name prominent, variant name secondary and smaller',
          'Added "View case study" links to relevant testimonials (FOSS Hack 2025)',
          'Live results counter shows number of visible testimonials',
          'Streamlined filter UI to single dropdown for cleaner, simpler design',
        ],
      },
      {
        category: 'Consulting Page',
        items: [
          'Added FOSS Hack 2025 case study section with stats (605 registrations, 217 participants, 4.5/5)',
          'Positioned above client testimonials with link to full blog post',
          'Used FOSS Hack code illustration from fossunited.org',
        ],
      },
      {
        category: 'Content & Terminology',
        items: [
          'Site-wide terminology change: replaced "students" with "attendees" across all pages, blog posts, and components',
          'Updated blog tag from "student-agency" to "attendee-agency"',
          'More inclusive language that reflects diverse learning audiences (employees, volunteers, community members)',
        ],
      },
      {
        category: 'Documentation',
        items: [
          'Added Google Form links to testimonial architecture docs',
          'Updated docs with both form-based and direct sheet editing workflows',
        ],
      },
    ],
  },
  {
    date: '2026-03-07',
    version: '1.6.0',
    title: 'Google Sheets testimonials system',
    changes: [
      {
        category: 'Testimonials',
        items: [
          'Migrated testimonials system from manual JSON editing to Google Sheets as single source of truth',
          'Added one-click deploy trigger from Google Sheet menu ("Website → Deploy to Live Site")',
          'Testimonials, products, partners, and persons data now auto-fetched from Google Sheets at build time',
          'Updated /testimonials page to display names, designations, and companies correctly',
          'Rewrote /docs/testimonial-architecture with complete documentation of the new workflow',
          'Updated /docs/testimonials-table to link directly to Google Sheets',
        ],
      },
      {
        category: 'Infrastructure',
        items: [
          'Added prebuild script to fetch fresh data from Google Sheets before every build',
          'Created fetch-testimonials.js script to pull data from 4 sheet tabs (Products, Partners, Persons, Form Responses)',
        ],
      },
    ],
  },
  {
    date: '2026-03-07',
    version: '1.5.0',
    title: 'Real World Ready event photos & image optimization',
    changes: [
      {
        category: 'Real World Ready Page',
        items: [
          'Replaced stock images with actual photos from Beyond the Blueprint sessions',
          'Added real event photos showing attendees participating in workshops and activities',
        ],
      },
      {
        category: 'Performance',
        items: [
          'Optimized event images folder from 134MB to 20MB (85% reduction)',
          'Resized images to max 1600px width at 80% quality for faster page loads',
        ],
      },
    ],
  },
  {
    date: '2026-02-25',
    version: '1.4.0',
    title: 'Clearer open source license guidelines',
    changes: [
      {
        category: 'Open Source Pages',
        items: [
          'Redesigned license section from 2 columns to 3 columns: "You can", "You cannot", "You must"',
          'Added visual icons for each permission type — green checkmarks for allowed, red X for prohibited, amber pins for requirements',
          'Clarified restrictions: no selling, no paid courses/cohorts/products, no commercial use without written permission',
          'Clarified requirements: credit The Second Design, retain license on adaptations, link to original source',
          'Hyperlinked "contact page" in the commercial licensing note for easy navigation',
        ],
      },
    ],
  },
  {
    date: '2026-02-25',
    version: '1.3.0',
    title: 'FOSS Hack 2025 case study & Proof of Work rebrand',
    changes: [
      {
        category: 'Blog',
        items: [
          'Published new case study: "What Happened When We Helped 200+ Attendees Prepare for FOSS Hack 2025"',
          'Details our Real World Ready collaboration with FOSS United — 605 registrations, 217 participants, 4.5/5 rating',
          'Includes embedded video testimonial from Rahul Poruri (CEO, FOSS United)',
        ],
      },
      {
        category: 'Proof of Work',
        items: [
          'Renamed "In Their Own Hands" show to "Proof of Work" — clearer name for attendee story videos',
          'Updated all navigation links and page routes to use /proof-of-work',
          'Refreshed episode detail page layout with improved video embedding',
        ],
      },
    ],
  },
  {
    date: '2026-02-25',
    version: '1.2.0',
    title: 'Real World Ready clarity updates & Contact form integration',
    changes: [
      {
        category: 'Real World Ready Page',
        items: [
          "Removed 'We also run open cohorts for individuals' — we work exclusively with organisations that serve young people",
          "Clarified session delivery — changed 'Run the free Shitty First Draft session' to 'Book a free Shitty First Draft session' across all CTAs",
          "Updated descriptive text to reflect that The Second Design conducts sessions for partners ('We run' / 'We'll run')",
          "Added single quotes around 'Shitty First Draft' throughout the page for clarity",
          "Linked 'Shitty First Draft' references to the /open-source page in paragraph text, so visitors can learn about the methodology",
        ],
      },
      {
        category: 'Contact Page',
        items: [
          'Replaced Netlify Forms with custom Google Sheets integration for form submissions',
          'All contact form entries now logged to a central Google Sheet with timestamp, name, email, organisation, interest, and message',
          'Added automatic email notifications — 4 team members now receive instant alerts when someone submits the contact form',
          'Added loading state with "Sending..." indicator while form submits',
          'Added success message confirmation when form submission completes',
          'Added error message with fallback guidance if submission fails',
        ],
      },
    ],
  },
  {
    date: '2026-02-25',
    version: '1.1.0',
    title: 'Content & UX improvements across the site',
    changes: [
      {
        category: 'Homepage',
        items: [
          'Updated hero subtitle to be more concise — changed "The Second Design is an Education Design Studio" to "We are an education design studio"',
          'Replaced "pedagogy" with "learning design" in the "What we do" note section',
          'Updated NGOs feature description to use "learning design" instead of "pedagogy"',
          'Refreshed blog section tagline to "instructional design and what we\'re learning"',
        ],
      },
      {
        category: 'Consulting Page',
        items: [
          'Updated hero intro copy — "We turn it into an unforgettable, transformative learning experience"',
          'Replaced "pedagogy" references with "learning design" throughout (3 instances)',
        ],
      },
      {
        category: 'Real World Ready Page',
        items: [
          'Changed section title from "How institutions get started" to "Bring this to your attendees"',
          'Redesigned the 3-step getting started section — now displays horizontally on desktop for a more compact layout',
          'Separated attendee testimonials from outcomes in the bento grid section',
          'Added new "Self-awareness" and "Confidence to act" outcome cards',
          'Created dedicated testimonials section with 5 named attendee quotes',
          'Updated testimonials to include attendee names and colleges where available (Nahidah from Jyothi Engineering College, Arjun Vibeesh, Deva, Arsha, Niranjana)',
        ],
      },
      {
        category: 'Open Source Pages',
        items: [
          'Changed resource links from "Open in Google Docs/Slides" to "Make a copy" — users now get their own editable copy directly',
          'Added CC BY-NC-SA 4.0 license with badge, updated license section with clear permissions and restrictions',
          'Updated hero badges from "Open for reuse with attribution" to clickable "CC BY-NC-SA 4.0" linking to Creative Commons',
          'Added license badges to project cards on the main /open-source listing page',
          'Fixed copy in Shitty First Draft page — changed "concrete shitty first draft" to "concrete first draft"',
        ],
      },
      {
        category: 'Navigation',
        items: [
          'Renamed "Pages" dropdown to "More" in the main navigation for clarity',
        ],
      },
      {
        category: 'Blog',
        items: [
          'Renamed blog post "Pedagogy of Cohort Based Courses" to "Learning Design in Cohort Based Courses"',
          'Updated blog post URL from /blog/pedagogy-of-cohort-based-courses to /blog/learning-design-in-cohort-based-courses',
          'Changed "Conventional pedagogy" to "Conventional teaching" in the post body',
        ],
      },
      {
        category: 'Infrastructure',
        items: [
          'Created CLAUDE.md file for Claude Code guidance when working in this repository',
          'Set up folder structure for Real World Ready event images at src/assets/images/real-world-ready/events/',
          'Created events.json metadata file for tracking session images by event, location, and date',
          'Added /changelog page to track website updates publicly',
        ],
      },
    ],
  },
];
---

<Layout metadata={metadata}>
  <section class="py-20 bg-white dark:bg-slate-950">
    <div class="container max-w-4xl mx-auto px-4 sm:px-6">
      <div class="space-y-4 mb-12">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-white">
          Changelog
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400">
          A record of updates and improvements to The Second Design website.
        </p>
      </div>

      <div class="space-y-16">
        {changelog.map((release) => (
          <article class="relative">
            <div class="flex items-center gap-4 mb-6">
              <time class="text-sm font-medium text-slate-500 dark:text-slate-400">
                {release.date}
              </time>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300">
                v{release.version}
              </span>
            </div>

            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8">
              {release.title}
            </h2>

            <div class="space-y-8">
              {release.changes.map((section) => (
                <div class="relative pl-6 border-l-2 border-slate-200 dark:border-slate-800">
                  <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-slate-200 dark:bg-slate-700 border-2 border-white dark:border-slate-950"></div>
                  <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-3">
                    {section.category}
                  </h3>
                  <ul class="space-y-2">
                    {section.items.map((item) => (
                      <li class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex gap-2">
                        <Icon name="tabler:check" class="w-4 h-4 text-emerald-500 flex-shrink-0 mt-0.5" />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
