---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import SessionAccordion from '~/components/widgets/SessionAccordion.astro';
import { getSessionsByGroup, plannedSessionsSummary } from '~/data/sessions';

// Event images
import heroImg from '~/assets/images/real-world-ready/events/btb-winter-camp-dec-2025/workshop-circle-01.jpg';
import collage1 from '~/assets/images/real-world-ready/events/btb-winter-camp-dec-2025/presenter-stage-01.jpg';
import collage2 from '~/assets/images/real-world-ready/events/btb-online-sessions/zoom-session-01.jpg';
import collage3 from '~/assets/images/real-world-ready/events/btb-summer-camp-feb-2025/session-openair-04.jpg';
import collage4 from '~/assets/images/real-world-ready/events/btb-summer-camp-feb-2025/recognition-01.jpg';
import outcomesImg from '~/assets/images/real-world-ready/events/btb-winter-camp-dec-2025/workshop-hall-01.jpg';
import collegesImg from '~/assets/images/real-world-ready/events/btb-winter-camp-dec-2025/workshop-hall-02.jpg';
import nonprofitsImg from '~/assets/images/real-world-ready/events/btb-summer-camp-feb-2025/session-openair-03.jpg';
import communitiesImg from '~/assets/images/real-world-ready/events/btb-online-sessions/zoom-session-01.jpg';
import formatsImg from '~/assets/images/real-world-ready/events/btb-winter-camp-dec-2025/students-working-01.jpg';
import btbCaseImg from '~/assets/images/real-world-ready/events/btb-winter-camp-dec-2025/presenter-hall-01.jpg';

// Online session images - showing real engagement
import sessionJan01 from '~/assets/images/real-world-ready/events/btb-online-sessions/session-jan2026-01.png';
import sessionJan02 from '~/assets/images/real-world-ready/events/btb-online-sessions/session-jan2026-02.png';
import sessionJan03 from '~/assets/images/real-world-ready/events/btb-online-sessions/session-jan2026-03.png';
import attendeesDec from '~/assets/images/real-world-ready/events/btb-online-sessions/attendees-dec2025.png';
import feedbackGeneral from '~/assets/images/real-world-ready/events/btb-online-sessions/session-mar2026-40participants.png';
import surveyDec01 from '~/assets/images/real-world-ready/events/btb-online-sessions/survey-dec2025-01.png';
import surveyDec05 from '~/assets/images/real-world-ready/events/btb-online-sessions/survey-dec2025-05.png';

const readySessions = getSessionsByGroup('ready-and-tested');
const upcomingSessions = getSessionsByGroup('upcoming');

const metadata = {
  title: 'Real World Ready',
  description:
    'A flagship program that helps young people build practical skills, habits, and mindsets for moving in the real world.',
};
---

<Layout metadata={metadata}>
  <!-- Hero ************************************* -->
  <section class="relative overflow-hidden min-h-[90vh] flex items-center bg-slate-950">
    <!-- Animated gradient background -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-violet-600/20 via-slate-950 to-emerald-600/20"></div>
      <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-violet-500/30 rounded-full blur-[120px] animate-pulse"></div>
      <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-emerald-500/20 rounded-full blur-[100px] animate-pulse" style="animation-delay: 1s;"></div>
    </div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:60px_60px]"></div>

    <div class="relative container max-w-7xl mx-auto px-4 sm:px-6 py-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Text -->
        <div class="max-w-2xl">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-sm mb-8">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-xs font-medium text-slate-300 tracking-wide">Flagship Program</span>
          </div>

          <!-- Main headline -->
          <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight text-white mb-6">
            Real World
            <span class="block bg-gradient-to-r from-violet-400 via-blue-400 to-emerald-400 bg-clip-text text-transparent">
              Ready
            </span>
          </h1>

          <p class="text-xl sm:text-2xl text-slate-400 leading-relaxed mb-10">
            Helping young people build the skills, habits, and inner tools to move in the real world: starting things, making decisions, and navigating careers with intention.
          </p>

          <!-- CTA -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/contact"
              class="group inline-flex items-center justify-center gap-2 rounded-full bg-white text-slate-900
                     px-8 py-4 text-sm font-semibold shadow-2xl shadow-white/20
                     hover:bg-slate-100 transition-all duration-300 hover:scale-105"
            >
              Book a free 'Shitty First Draft' session
              <Icon name="tabler:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
            </a>
            <a
              href="#case-studies"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-white/5 border border-white/10 text-white
                     px-8 py-4 text-sm font-semibold backdrop-blur-sm
                     hover:bg-white/10 transition-all duration-300"
            >
              See it in action
            </a>
          </div>
        </div>

        <!-- Hero Image -->
        <div class="relative hidden lg:block">
          <div class="absolute -inset-4 bg-gradient-to-tr from-violet-500/20 via-blue-500/10 to-emerald-500/20 rounded-3xl blur-2xl"></div>
          <div class="relative rounded-3xl overflow-hidden border border-white/10 shadow-2xl shadow-black/50">
            <img
              src={heroImg.src}
              alt="Beyond the Blueprint workshop session with attendees"
              class="w-full aspect-[4/3] object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <div class="flex items-center gap-3">
                <img src="https://avatars.githubusercontent.com/u/65708026?s=200&v=4" alt="TinkerHub" class="h-8 w-8 rounded-lg" />
                <img src="https://fossunited.org/files/foss-united-logo.svg" alt="FOSS United" class="h-6 w-auto invert opacity-80" />
                <span class="text-white/60 text-sm ml-2">& more partners</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-500">
      <span class="text-xs tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-slate-500 to-transparent"></div>
    </div>
  </section>

  <!-- What makes it different ***************** -->
  <section class="py-24 sm:py-32 bg-white dark:bg-slate-950 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-slate-200 dark:via-slate-800 to-transparent"></div>

    <div class="container max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Image collage -->
        <div class="relative order-2 lg:order-1">
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <div class="rounded-2xl overflow-hidden shadow-lg">
                <img
                  src={collage1.src}
                  alt="Presenter on stage at Beyond the Blueprint"
                  class="w-full aspect-[4/5] object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="rounded-2xl overflow-hidden shadow-lg">
                <img
                  src={collage2.src}
                  alt="Online Zoom session with attendees"
                  class="w-full aspect-square object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
            </div>
            <div class="space-y-4 pt-8">
              <div class="rounded-2xl overflow-hidden shadow-lg">
                <img
                  src={collage3.src}
                  alt="Workshop session in open-air venue"
                  class="w-full aspect-square object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="rounded-2xl overflow-hidden shadow-lg">
                <img
                  src={collage4.src}
                  alt="Attendee recognition moment at workshop"
                  class="w-full aspect-[4/5] object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Text content -->
        <div class="space-y-8 order-1 lg:order-2">
          <div class="space-y-4">
            <p class="text-sm font-semibold tracking-[0.2em] text-violet-600 dark:text-violet-400 uppercase">The Approach</p>
            <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 dark:text-white">
              Not lectures.<br/>
              <span class="text-slate-400 dark:text-slate-500">Real practice.</span>
            </h2>
          </div>
          <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
            Real World Ready is not about motivational speeches or neat lists of "skills". It's a sequence of experiences where attendees actually do things: start projects, make decisions, communicate, and see themselves differently.
          </p>

          <div class="grid gap-4">
            <!-- Card 1 -->
            <div class="group relative p-6 rounded-2xl bg-gradient-to-br from-violet-500/10 to-violet-500/5 border border-violet-500/20 hover:border-violet-500/40 transition-all duration-300">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-violet-500/20 flex items-center justify-center">
                  <Icon name="tabler:sparkles" class="w-6 h-6 text-violet-500 dark:text-violet-400" />
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Practice-heavy sessions</h3>
                  <p class="text-sm text-slate-600 dark:text-slate-400">Attendees actually do things in the session, not passive lectures.</p>
                </div>
              </div>
            </div>

            <!-- Card 2 -->
            <div class="group relative p-6 rounded-2xl bg-gradient-to-br from-blue-500/10 to-blue-500/5 border border-blue-500/20 hover:border-blue-500/40 transition-all duration-300">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center">
                  <Icon name="tabler:route" class="w-6 h-6 text-blue-500 dark:text-blue-400" />
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Systems thinking</h3>
                  <p class="text-sm text-slate-600 dark:text-slate-400">Careers and projects as systems, broken into small, deliberate experiments.</p>
                </div>
              </div>
            </div>

            <!-- Card 3 -->
            <div class="group relative p-6 rounded-2xl bg-gradient-to-br from-emerald-500/10 to-emerald-500/5 border border-emerald-500/20 hover:border-emerald-500/40 transition-all duration-300">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center">
                  <Icon name="tabler:rocket" class="w-6 h-6 text-emerald-500 dark:text-emerald-400" />
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Ship real work</h3>
                  <p class="text-sm text-slate-600 dark:text-slate-400">Real-world projects and outreach, not just "doing assignments".</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Real engagement proof ******************** -->
  <section class="py-20 bg-gradient-to-br from-slate-50 to-white dark:from-slate-900/50 dark:to-slate-950">
    <div class="container max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="text-sm font-semibold tracking-[0.2em] text-violet-600 dark:text-violet-400 uppercase mb-4">Real Results</p>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-slate-900 dark:text-white mb-4">
          Not theory. Actual attendee participation.
        </h2>
        <p class="text-base text-slate-600 dark:text-slate-400">
          Screenshots from live sessions showing attendees actively working, sharing ideas, and giving feedback.
        </p>
      </div>

      <!-- Large group photo showing scale -->
      <div class="mb-12">
        <div class="relative rounded-3xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-2xl">
          <img
            src={attendeesDec.src}
            alt="Large group of attendees participating in online Real World Ready session"
            class="w-full h-auto"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
            <div class="max-w-3xl">
              <p class="text-sm font-semibold tracking-wide text-violet-300 uppercase mb-2">At Scale</p>
              <h3 class="text-2xl sm:text-3xl font-bold mb-3">
                Hundreds of attendees, fully engaged
              </h3>
              <p class="text-white/90 text-base">
                From intimate cohorts to large-scale bootcamps with 200+ attendees — Real World Ready maintains engagement and quality at every scale.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Session screenshots grid -->
      <div class="grid md:grid-cols-3 gap-6">
        <div class="group relative rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-lg hover:shadow-xl transition-all duration-300">
          <img
            src={sessionJan01.src}
            alt="Online session with attendees actively participating and sharing work"
            class="w-full h-auto"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
            <p class="text-white text-sm font-medium">Attendees sharing their work in real-time</p>
          </div>
        </div>

        <div class="group relative rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-lg hover:shadow-xl transition-all duration-300">
          <img
            src={sessionJan03.src}
            alt="Session showing attendees actively working and collaborating"
            class="w-full h-auto"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
            <p class="text-white text-sm font-medium">Active collaboration during exercises</p>
          </div>
        </div>

        <div class="group relative rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-lg hover:shadow-xl transition-all duration-300">
          <img
            src={feedbackGeneral.src}
            alt="40 participants in an online Real World Ready session on March 2026"
            class="w-full h-auto"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
            <p class="text-white text-sm font-medium">Real-time feedback during sessions</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sessions ********************************* -->
  <section class="py-24 sm:py-32 bg-slate-50 dark:bg-slate-900/50">
    <div class="container max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-sm font-semibold tracking-[0.2em] text-violet-600 dark:text-violet-400 uppercase mb-4">Sessions</p>
        <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 dark:text-white mb-6">
          Topics we cover
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-400">
          Each session is a focused, practice-heavy experience designed around a specific problem attendees face.
        </p>
      </div>

      <SessionAccordion
        readySessions={readySessions}
        upcomingSessions={upcomingSessions}
        plannedSummary={plannedSessionsSummary}
      />
    </div>
  </section>

  <!-- How Institutions Get Started ************* -->
  <section class="py-24 sm:py-32 bg-slate-50 dark:bg-slate-900/50">
    <div class="container max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-sm font-semibold tracking-[0.2em] text-emerald-600 dark:text-emerald-400 uppercase mb-4">Getting Started</p>
        <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 dark:text-white mb-6">
          Bring this to your students
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-400">
          A low-risk path from first experience to full adoption. Start with a free session and decide from there.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- Step 1 -->
        <div class="relative p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center">
              <Icon name="tabler:player-play" class="w-6 h-6 text-emerald-600 dark:text-emerald-400" />
            </div>
            <div>
              <span class="text-xs font-bold tracking-widest text-emerald-600 dark:text-emerald-400 uppercase">Step 1</span>
              <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-700 dark:text-emerald-300 border border-emerald-500/20">Free</span>
            </div>
          </div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Experience</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
            We run a free online '<a href="/open-source" class="underline hover:no-underline">Shitty First Draft</a>' session for your attendees. They participate, faculty observe. No logistics, no cost.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center">
              <Icon name="tabler:eye-check" class="w-6 h-6 text-blue-600 dark:text-blue-400" />
            </div>
            <span class="text-xs font-bold tracking-widest text-blue-600 dark:text-blue-400 uppercase">Step 2</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Evaluate</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
            Your team reflects on the fit. Did attendees engage? Does the approach match your goals? No pressure, no commitment.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center">
              <Icon name="tabler:arrow-fork" class="w-6 h-6 text-violet-600 dark:text-violet-400" />
            </div>
            <span class="text-xs font-bold tracking-widest text-violet-600 dark:text-violet-400 uppercase">Step 3</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Deepen</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
            Choose what works for you: on-campus workshops or an online series. We tailor sessions to your context.
          </p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a
          href="/contact"
          class="group inline-flex items-center justify-center gap-2 rounded-full bg-emerald-600 text-white
                 px-8 py-4 text-sm font-semibold shadow-lg shadow-emerald-500/20
                 hover:bg-emerald-700 transition-all duration-300 hover:scale-105"
        >
          Book a free 'Shitty First Draft' session
          <Icon name="tabler:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
        </a>
      </div>
    </div>
  </section>

  <!-- Featured: Shitty First Draft Impact ******* -->
  <section class="py-20 bg-white dark:bg-slate-950">
    <div class="container max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <p class="text-sm font-semibold tracking-[0.2em] text-violet-600 dark:text-violet-400 uppercase mb-4">
          Real Impact
        </p>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-slate-900 dark:text-white mb-4">
          What happens in a 'Shitty First Draft' session
        </h2>
        <p class="text-base text-slate-600 dark:text-slate-400">
          Attendees describe how one 90-minute session shifted their approach to starting, creating, and overcoming perfectionism.
        </p>
      </div>

      <div class="relative rounded-3xl overflow-hidden border-2 border-violet-200 dark:border-violet-900 shadow-2xl shadow-violet-500/20">
        <img
          src={surveyDec05.src}
          alt="Detailed attendee feedback showing concrete takeaways and mindset shifts from the Shitty First Draft session"
          class="w-full h-auto"
        />
      </div>

      <div class="text-center mt-8">
        <p class="text-sm text-slate-500 dark:text-slate-400 italic">
          Actual responses from attendees after their first session
        </p>
      </div>
    </div>
  </section>

  <!-- Survey feedback evidence ***************** -->
  <section class="py-20 bg-slate-50 dark:bg-slate-900/50">
    <div class="container max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="text-sm font-semibold tracking-[0.2em] text-blue-600 dark:text-blue-400 uppercase mb-4">Immediate Feedback</p>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-slate-900 dark:text-white mb-4">
          63% rated it 10/10
        </h2>
        <p class="text-base text-slate-600 dark:text-slate-400">
          Real-time reactions and post-session ratings from attendees.
        </p>
      </div>

      <!-- Featured: Rating chart showing 63% gave 10/10 -->
      <div class="mb-8">
        <div class="relative rounded-3xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-2xl hover:shadow-3xl transition-all duration-300">
          <img
            src={surveyDec01.src}
            alt="Survey showing 63% of attendees rated the session 10/10"
            class="w-full h-auto"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 via-transparent to-transparent pointer-events-none"></div>
        </div>
      </div>

      <!-- Chat feedback -->
      <div class="max-w-2xl mx-auto">
