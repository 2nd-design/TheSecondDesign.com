---
import Layout from '~/layouts/PageLayout.astro';

import testimonialsData from '~/data/testimonials.json';
import personsData from '~/data/persons.json';
import productsData from '~/data/products.json';

const metadata = {
  title: 'Testimonials',
  description: 'What partners, organisations, and learners say about working with The Second Design.',
};

interface Testimonial {
  testimonial_id: string;
  person_id: string | null;
  product_ids?: string[];
  partner_ids?: string[];
  quote_short: string;
  source_type: string;
  source_url: string | null;
  audience_type?: string | null;
  scope?: string;
  priority?: string | null;
  language?: string | null;
  date?: string | null;
  is_published?: boolean;
}

interface Person {
  person_id: string;
  name: string;
  designation: string | null;
  company: string | null;
  partner_id?: string | null;
  relationship_type?: string | null;
}

interface Product {
  product_id: string;
  name: string;
  category?: string | null;
  variant_name?: string | null;
}

const testimonials = (testimonialsData as Testimonial[]).filter((t) => t.is_published !== false);

const persons = personsData as Person[];
const products = productsData as Product[];

const personsMap = new Map(persons.map((p) => [p.person_id, p]));
const productsMap = new Map(products.map((p) => [p.product_id, p]));

function getProductLabelFromId(productId: string | null): string {
  if (!productId || productId === 'generic-brand') {
    return 'The Second Design – Brand';
  }

  const p = productsMap.get(productId);
  if (!p) return 'The Second Design – Brand';

  // Show variant name if available, otherwise product name
  if (p.variant_name) {
    return `${p.name} – ${p.variant_name}`;
  }
  return p.name || 'The Second Design – Brand';
}

function getProductLabelForTestimonial(t: Testimonial): string {
  const firstId = t.product_ids && t.product_ids.length > 0 ? t.product_ids[0] : 'generic-brand';
  return getProductLabelFromId(firstId);
}

function getProductNameAndVariant(productId: string | null): { name: string; variant: string | null } {
  if (!productId || productId === 'generic-brand') {
    return { name: 'The Second Design', variant: 'Brand' };
  }

  const p = productsMap.get(productId);
  if (!p) return { name: 'The Second Design', variant: 'Brand' };

  return {
    name: p.name || 'The Second Design',
    variant: p.variant_name || null,
  };
}

function getPerson(t: Testimonial): Person | null {
  if (!t.person_id) return null;
  return personsMap.get(t.person_id) ?? null;
}

function getAudienceLabel(t: Testimonial, person: Person | null): string {
  if (person?.name) return person.name;
  if (t.audience_type) {
    const a = t.audience_type;
    return a.charAt(0).toUpperCase() + a.slice(1);
  }
  return 'Learner';
}

function getSourceLabel(t: Testimonial): string {
  switch (t.source_type) {
    case 'video':
      return 'Video';
    case 'blog':
      return 'Blog';
    case 'email':
      return 'Email';
    case 'text':
    default:
      return 'Text';
  }
}

function getSourceCta(t: Testimonial): string {
  switch (t.source_type) {
    case 'video':
      return 'Watch video';
    case 'blog':
      return 'Read blog';
    case 'email':
      return 'View note';
    default:
      return 'Open';
  }
}

function extractYouTubeId(url: string | null): string | null {
  if (!url) return null;
  try {
    const u = new URL(url);
    if (u.hostname === 'youtu.be') {
      return u.pathname.slice(1);
    }
    const v = u.searchParams.get('v');
    if (v) return v;
    if (u.pathname.startsWith('/embed/')) {
      const parts = u.pathname.split('/');
      return parts[2] || null;
    }
    if (u.pathname.startsWith('/shorts/')) {
      const parts = u.pathname.split('/');
      return parts[2] || null;
    }
    return null;
  } catch {
    return null;
  }
}

function getCaseStudyLink(productId: string | null): string | null {
  if (productId === 'rwr-foss2025') return '/blog/real-world-ready-foss-hack-2025';
  // Add more case study links as they're created
  return null;
}

// Get unique filter options - group by base product name
const productsByName = new Map<string, string[]>();
const usedProductIds = new Set(
  testimonials.flatMap((t) => t.product_ids || []).filter((id) => id !== 'generic-brand')
);

usedProductIds.forEach((id) => {
  const product = productsMap.get(id);
  if (product) {
    const baseName = product.name;
    if (!productsByName.has(baseName)) {
      productsByName.set(baseName, []);
    }
    productsByName.get(baseName)!.push(id);
  }
});

const uniqueProducts = Array.from(productsByName.entries())
  .map(([name, ids]) => ({
    name,
    ids,
  }))
  .sort((a, b) => a.name.localeCompare(b.name));

---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="py-24 text-center bg-white dark:bg-slate-950">
    <div class="container max-w-3xl mx-auto space-y-6 px-4 sm:px-6">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 dark:text-slate-50">Testimonials</h1>
      <p class="text-lg sm:text-xl text-slate-700 dark:text-slate-300 leading-relaxed">
        Voices from partners, organisations, and learners who've been through our programs and consulting work.
      </p>
    </div>
  </section>

  <!-- Filters -->
  <section class="py-6 bg-white dark:bg-slate-950 border-b border-slate-200 dark:border-slate-800">
    <div class="container max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col sm:flex-row gap-3 items-start sm:items-center">
        <span class="text-sm text-slate-600 dark:text-slate-400">Filter:</span>

        <select
          id="product-filter"
          class="px-3 py-1.5 text-sm border border-slate-300 rounded-lg bg-white dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200"
        >
          <option value="all">All Products</option>
          {uniqueProducts.map((product) => (
            <option value={product.ids.join(',')}>{product.name}</option>
          ))}
        </select>

        <span class="text-xs text-slate-500 dark:text-slate-400 sm:ml-auto">
          <span id="results-count">{testimonials.length}</span> / {testimonials.length}
        </span>
      </div>
    </div>
  </section>

  <!-- Masonry wall -->
  <section class="py-20 bg-slate-50 dark:bg-slate-950/70">
    <div class="container max-w-6xl mx-auto px-4 sm:px-6 space-y-8">
      <div id="testimonials-grid" class="columns-1 sm:columns-2 lg:columns-3 gap-6">
        {
          testimonials.map((t) => {
            const person = getPerson(t);
            const audienceLabel = getAudienceLabel(t, person);
            const productNameVariant = getProductNameAndVariant(t.product_ids?.[0] || null);
            const sourceLabel = getSourceLabel(t);
            const youtubeId = extractYouTubeId(t.source_url);
            const caseStudyLink = getCaseStudyLink(t.product_ids?.[0] || null);

            return (
              <article
                class="testimonial-card mb-6 break-inside-avoid rounded-2xl p-6 sm:p-7 border bg-white border-slate-200 shadow-sm shadow-slate-200/70 dark:bg-slate-900/70 dark:border-slate-800 dark:shadow-black/30 flex flex-col gap-4"
                data-product-ids={JSON.stringify(t.product_ids || [])}
                data-audience-type={t.audience_type || ''}
                data-partner-ids={JSON.stringify(t.partner_ids || [])}
              >
                {/* Person info at top */}
                <div class="flex items-center justify-between gap-3">
                  <div class="flex items-center gap-3">
                    <div class="h-9 w-9 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-xs font-semibold text-slate-700 dark:text-slate-200">
                      {person?.name ? person.name.charAt(0) : audienceLabel.charAt(0)}
                    </div>
                    <div>
                      <div class="text-sm font-semibold text-slate-900 dark:text-slate-50">
                        {person?.name ?? audienceLabel}
                      </div>
                      <div class="text-xs text-slate-500 dark:text-slate-400">
                        {person?.designation}
                        {person?.designation && person?.company ? ' · ' : ''}
                        {person?.company}
                      </div>
                    </div>
                  </div>

                  <div class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-slate-100 text-[11px] font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                    {sourceLabel}
                    {t.language && t.language !== 'en' && <span class="opacity-70">· {t.language.toUpperCase()}</span>}
                  </div>
                </div>

                {/* Quote */}
                <p class="text-base sm:text-lg text-slate-800 dark:text-slate-100 leading-relaxed">"{t.quote_short}"</p>

                {/* Case study link */}
                {caseStudyLink && (
                  <div class="mt-1">
                    <a
                      href={caseStudyLink}
                      class="inline-flex items-center gap-1.5 text-xs font-semibold text-blue-600 dark:text-blue-400 hover:underline"
                    >
                      View case study →
                    </a>
                  </div>
                )}

                {/* Source-specific render */}
                {t.source_type === 'video' && youtubeId && (
                  <div class="mt-1 aspect-video rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800">
                    <iframe
                      src={`https://www.youtube.com/embed/${youtubeId}`}
                      title="Video testimonial"
                      loading="lazy"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      allowfullscreen
                      class="w-full h-full"
                    />
                  </div>
                )}

                {t.source_type === 'blog' && t.source_url && (
                  <div class="mt-1">
                    <a
                      href={t.source_url}
                      target="_blank"
                      rel="noreferrer"
                      class="inline-flex items-center gap-1.5 text-xs font-semibold text-blue-600 dark:text-blue-400 hover:underline"
                    >
                      Read the full story
                      <span aria-hidden="true">↗</span>
                    </a>
                  </div>
                )}

                {t.source_type === 'email' && t.source_url && (
                  <div class="mt-1">
                    <a
                      href={t.source_url}
                      target="_blank"
                      rel="noreferrer"
                      class="inline-flex items-center gap-1.5 text-xs font-semibold text-blue-600 dark:text-blue-400 hover:underline"
                    >
                      View original note
                      <span aria-hidden="true">↗</span>
                    </a>
                  </div>
                )}

                {/* Product info at bottom - prominent base name, secondary variant */}
                <div class="mt-auto pt-3 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between gap-3">
                  <div>
                    <div class="text-sm font-semibold text-slate-900 dark:text-slate-50">
                      {productNameVariant.name}
                    </div>
                    {productNameVariant.variant && (
                      <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                        {productNameVariant.variant}
                      </div>
                    )}
                  </div>

                  {t.source_url && !youtubeId && t.source_type !== 'blog' && !caseStudyLink && (
                    <a
                      href={t.source_url}
                      target="_blank"
                      rel="noreferrer"
                      class="text-xs font-semibold text-blue-600 dark:text-blue-400 hover:underline whitespace-nowrap"
                    >
                      {getSourceCta(t)}
                    </a>
                  )}
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 text-center bg-white dark:bg-slate-950">
    <div class="container max-w-3xl mx-auto space-y-6 px-4 sm:px-6">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-slate-50">
        Want to work with The Second Design?
      </h2>
      <p class="text-slate-700 dark:text-slate-300 text-base leading-relaxed">
        Whether you're a college, NGO, foundation, or company, we're happy to explore building a serious learning
        program with you.
      </p>

      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-xl
               bg-slate-900 text-slate-50 px-6 py-3 text-sm font-semibold
               shadow-lg shadow-blue-500/30 hover:bg-slate-800
               dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100
               transition"
      >
        Book an inquiry call
      </a>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const cards = document.querySelectorAll('.testimonial-card');
      const productFilter = document.getElementById('product-filter') as HTMLSelectElement;
      const resultsCount = document.getElementById('results-count');

      function filterTestimonials() {
        let visibleCount = 0;
        const productValue = productFilter?.value || 'all';

        cards.forEach((card) => {
          const productIds = JSON.parse(card.getAttribute('data-product-ids') || '[]');

          // Product filter uses comma-separated list of IDs for product groups
          let matchesProduct = productValue === 'all';
          if (!matchesProduct && productValue) {
            const selectedProductIds = productValue.split(',');
            matchesProduct = productIds.some((id: string) => selectedProductIds.includes(id));
          }

          if (matchesProduct) {
            (card as HTMLElement).style.display = '';
            visibleCount++;
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });

        if (resultsCount) {
          resultsCount.textContent = visibleCount.toString();
        }
      }

      productFilter?.addEventListener('change', filterTestimonials);
    });
  </script>
</Layout>
