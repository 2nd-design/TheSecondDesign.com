---
import type { ImageMetadata } from 'astro';
import Image from '~/components/common/Image.astro';

import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

import { getPermalink } from '~/utils/permalinks';
import { findImage } from '~/utils/images';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const image = (await findImage(post.image)) as ImageMetadata | undefined;

const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
---

<article class="group py-8 border-b border-slate-100 dark:border-slate-800 last:border-0">
  <div class="flex items-start justify-between gap-8">
    <div class="flex-1 min-w-0">
      {post.category && (
        <a
          href={getPermalink(post.category.slug, 'category')}
          class="text-xs font-bold tracking-widest uppercase text-primary dark:text-blue-400 mb-2 block hover:opacity-70 transition-opacity"
        >
          {post.category.title}
        </a>
      )}
      <h2 class="text-xl md:text-2xl font-bold leading-snug font-heading text-slate-900 dark:text-slate-100 group-hover:text-primary dark:group-hover:text-blue-400 transition-colors duration-200">
        {
          link ? (
            <a href={link}>{post.title}</a>
          ) : (
            post.title
          )
        }
      </h2>
      {post.excerpt && (
        <p class="mt-2 text-slate-500 dark:text-slate-400 text-base line-clamp-2 leading-relaxed">{post.excerpt}</p>
      )}
      <div class="mt-3 flex items-center gap-2 text-xs text-slate-400 dark:text-slate-500">
        <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
        {post.readingTime && <><span>·</span><span>{post.readingTime} min read</span></>}
      </div>
    </div>
    {
      image && link && (
        <a href={link} class="flex-shrink-0 hidden sm:block">
          <div class="w-32 h-22 md:w-40 md:h-28 overflow-hidden rounded-lg bg-gray-200 dark:bg-slate-700 group-hover:opacity-90 transition-opacity duration-200">
            <Image
              src={image}
              class="object-cover w-full h-full"
              widths={[160, 320]}
              width={160}
              height={112}
              sizes="160px"
              alt={post.title}
              loading="lazy"
              decoding="async"
            />
          </div>
        </a>
      )
    }
  </div>
</article>
